<!DOCTYPE html>
<html lang="nl-BE">
<head>
    <meta charset="UTF-8">
    <title>Page</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0&icon_names=person" />
</head>
<body class="text-white min-h-screen flex flex-col">
<header class="sticky w-full bg-[#003652]">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center relative">
        <!-- Logo -->
        <a class="flex items-center" href="/homepage">
            <img alt="Gameforge logo" class="h-16 w-auto" src="/assets/img/logo.png">
        </a>
        <a class="font-extralight hover:underline uppercase" href="/guessthegame">Guess the game</a>

        <!-- Searchbox -->
        <div class="absolute left-1/2 transform -translate-x-1/2 w-full max-w-md">
            <input class="w-full px-4 py-2 rounded-lg border outline-none focus:ring-2 text-black" placeholder="Search games..." type="search">
        </div>

        <!-- Navbar Buttons -->
        <nav class="ml-auto flex items-center gap-6">
            <a class="font-medium hover:underline" href="/homepage">Home</a>
            <a class="font-medium hover:underline" href="/collections">Collecties</a>
            <a class="font-medium hover:underline" href="/profile">
                <span class="material-symbols-outlined">person</span>
            </a>
        </nav>
    </div>
</header>

<main class="bg-[#001B29] flex-1">
    <div id="game-detail">
        <% if (error) { %>
            <p class="text-center mt-10"><%= error %></p>
        <% } else if (game) { %>
            <%
                const platforms = game.platforms.map((p) => p.platform.name).join(", ");
            %>
            <div class="max-w-6xl mx-auto px-4 py-10">

                <div class="relative">
                    <img src="<%= game.background_image %>"
                         class="w-full h-[400px] object-cover rounded-xl opacity-80">
                    <div class="absolute bottom-4 left-6">
                        <h1 class="text-4xl font-bold"><%= game.name %></h1>
                        <p class="text-gray-300">Released: <%= game.released %></p>
                    </div>
                </div>

                <div class="grid md:grid-cols-3 gap-8 mt-8">

                    <div class="md:col-span-2 flex flex-col gap-6">

                        <div>
                            <h2 class="text-2xl font-semibold mb-2">Description</h2>
                            <p class="text-gray-300 leading-relaxed whitespace-pre-line">
                                <%= game.description_raw %>
                            </p>
                        </div>

                        <div>
                            <h2 class="text-xl font-semibold mb-2">Tags</h2>
                            <div class="flex flex-wrap gap-2">
                                <% game.tags.slice(0, 8).forEach((tag) => { %>
                                    <span class="bg-gray-700 px-2 py-1 rounded text-xs">
                                        <%= tag.name %>
                                    </span>
                                <% }); %>
                            </div>
                        </div>

                    </div>

                    <div class="flex flex-col gap-6">

                        <div class="bg-[#003652] p-4 rounded-xl">
                            <h3 class="text-lg font-semibold">Rating</h3>
                            <p class="text-2xl font-bold text-yellow-400">
                                ⭐ <%= game.rating %> / 5
                            </p>
                        </div>

                        <div class="bg-[#003652] p-4 rounded-xl">
                            <h3 class="text-lg font-semibold mb-2">Genres</h3>
                            <div class="flex flex-wrap gap-2">
                                <% game.genres.forEach((genre) => { %>
                                    <span class="bg-[#003652] px-3 py-1 rounded-lg text-sm">
                                        <%= genre.name %>
                                    </span>
                                <% }); %>
                            </div>
                        </div>

                        <div class="bg-[#003652] p-4 rounded-xl">
                            <h3 class="text-lg font-semibold">Platforms</h3>
                            <p class="text-gray-300"><%= platforms %></p>
                        </div>

                        <div class="bg-[#003652] p-4 rounded-xl">
                            <h3 class="text-lg font-semibold">Website</h3>
                            <a href="<%= game.website %>" target="_blank"
                               class="text-blue-400 hover:underline break-all">
                                <%= game.website %>
                            </a>
                        </div>

                    </div>

                </div>
            </div>
        <% } %>
    </div>
</main>

<footer class="bg-[#003652] py-6">
    <div class="flex flex-col items-center">
        <span class="text-[11px]">© 2026 GameForge</span>
        <span class="text-[11px]">All rights reserved</span>
        <a href="https://rawg.io" target="_blank" class="font-medium hover:underline text-[11px]">
            source of data used is RAWG API
        </a>
    </div>
</footer>
</body>
</html>
