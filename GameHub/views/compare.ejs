<!DOCTYPE html>
<html lang="nl-BE">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>

    <link rel="stylesheet" href="/css/reset.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/aside.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/compare.css">
</head>

<body>
    <%- include("partials/header", { searchbar: true }) %>

    <div class="page-layout">
        <%- include("partials/aside", { showFilters: false }) %>

        <main class="compare-main">
            <div class="compare-wrapper">
                <a href="/home" class="leave-compare-link">Game vergelijking verlaten</a>

                <section class="compare-grid" aria-label="Game vergelijking">
                    <% games.forEach(game => { %>
                        <article class="compare-card">
                            <img src="<%= game.image %>" alt="<%= game.name %>">

                            <h1><%= game.name %></h1>

                            <section>
                                <h2>Genre</h2>
                                <p><%= game.genres.join(", ") %></p>
                            </section>

                            <section>
                                <h2>Platform(s)</h2>
                                <p><%= game.platforms.join(", ") %></p>
                            </section>

                            <section>
                                <h2>Rating</h2>
                                <p><%= game.rating %></p>
                            </section>

                            <section>
                                <h2>Beschrijving</h2>
                                <p class="description"><%= game.description %></p>
                            </section>

                            <section>
                                <h2>Gemiddelde speeltijd</h2>
                                <p><%= game.playtime %> uur</p>
                            </section>
                        </article>
                    <% }) %>
                </section>
            </div>
        </main>
    </div>

    <%- include("partials/footer") %>
</body>
</html>