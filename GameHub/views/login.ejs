<!DOCTYPE html>
<html lang="en">
<%- include("partials/head", {page:"login", title:"Login"}) %>

    <body>
        <main class="login-page">
            <img class="logo" src="/images/b-hive-lg.png" alt="Logo B-Hive">
            <section>
                <form class="login-box" action="/login" method="POST">
                    <h1>Login</h1>
                    <div class="form-group">
                        <label for="email">E-mail</label>
                        <input type="email" id="email" name="email" required>
                    </div>

                    <div class="form-group">
                        <label for="password">Wachtwoord</label>
                        <input type="password" id="password" name="password" required>
                    </div>

                    <div class="button-group">
                        <button type="submit">Inloggen</button>
                        <button class="secondary-btn">
                            <a href="/register">Create account</a>
                        </button>
                    </div>
                </form>
                <div class="under-menu">
                    <a href="/" class="back-btn">Back to Projects</a>
                    <a href="/Home" class="back-btn">Skip login</a>
                </div>
            </section>

        </main>

        <%- include("./partials/footer") %>

    </body>

</html>