<!DOCTYPE html>
<html lang="nl-BE">
<%- include("partials/head", {page:"collection", title:collection.name}) %>

    <body>
        <%- include("partials/header", { searchbar: true }) %>

            <div class="page-layout">
                <%- include("partials/aside", { showFilters: true }) %>

                    <main class="collections-main">
                        <div class="collections-wrapper">

                            <% if (!collection) { %>
                                <p>Collectie niet gevonden.</p>
                                <% } else { %>

                                    <h1>
                                        <%= collection.name %>
                                    </h1>

                                    <% if (collection.description) { %>
                                        <p>
                                            <%= collection.description %>
                                        </p>
                                        <% } %>

                                            <section class="collections-actions" aria-label="Acties">
                                                <button type="button">Game toevoegen</button>
                                                <button type="button">Collectie bewerken</button>
                                            </section>

                                            <section class="collections-grid" aria-label="Games in collectie">
                                                <% if (collection.games.length===0) { %>
                                                    <p>Deze collectie bevat nog geen games.</p>
                                                    <% } else { %>
                                                        <% collection.games.forEach(game=> { %>
                                                            <article class="collection-card">
                                                                <a href="/game/<%= game.slug %>">
                                                                    <img src="<%= game.image %>" alt="<%= game.name %>">
                                                                    <h2>
                                                                        <%= game.name %>
                                                                    </h2>
                                                                    <p>⭐ <%= game.rating %>
                                                                    </p>
                                                                    <p>
                                                                        <%= game.released %>
                                                                    </p>
                                                                </a>
                                                            </article>
                                                            <% }) %>
                                                                <% } %>
                                            </section>
                                            <% } %>
                        </div>
                    </main>
            </div>
            <%- include("partials/footer") %>
    </body>

</html>