<!DOCTYPE html>
<html lang="nl-BE">
<%- include("partials/head", {page:"home", title:"GameHub"}) %>

<body>
    <%- include("partials/header", { searchbar: true }) %>

    <div class="page-layout">
        <%- include("partials/aside", { showFilters: true }) %>

        <main class="home-main">
            <div class="home-wrapper">
                <h1>Games ontdekken</h1>

                <section class="home-grid">
                    <% games.forEach(game => { %>
                        <article class="game-card">
                            <div class="card-actions">
                                <button class="add-btn" type="button">Add</button>

                                <button
                                    class="compare-btn"
                                    type="button"
                                    data-name="<%= game.name %>"
                                    data-image="<%= game.image %>"
                                    data-slug="<%= game.slug %>"
                                >
                                    Compare
                                </button>
                            </div>

                            <a href="/game/<%= game.slug %>">
                                <img src="<%= game.image %>" alt="<%= game.name %>">
                                <h2><%= game.name %></h2>
                                <p>⭐ <%= game.rating %></p>
                                <p><%= game.released %></p>
                            </a>
                        </article>
                    <% }) %>
                </section>
            </div>
        </main>
    </div>

    <section class="compare-bar" id="compareBar">
        <div class="compare-slot" data-slot="0">
            <p>Game 1</p>
        </div>

        <div class="compare-slot" data-slot="1">
            <p>Game 2</p>
        </div>

        <a href="/compare" class="compare-page-btn" id="comparePageBtn">
            Vergelijk
        </a>
    </section>

    <%- include("partials/footer") %>
</body>
</html>